{
  "name": "@zhaoyuanjie/baliclaw",
  "version": "0.8.2",
  "description": "Yet another Claw built on Claude Agent SDK.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/zhaoyouqi/baliclaw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhaoyouqi/baliclaw.git"
  },
  "bugs": {
    "url": "https://github.com/zhaoyouqi/baliclaw/issues"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.3",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist/",
    "resources/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "baliclaw": "dist/cli/index.js",
    "baliclawd": "dist/daemon/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli/index.ts status",
    "prepublishOnly": "pnpm build && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "commander": "^14.0.0",
    "grammy": "^1.42.0",
    "https-proxy-agent": "^9.0.0",
    "json5": "^2.2.3",
    "pino": "^10.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
